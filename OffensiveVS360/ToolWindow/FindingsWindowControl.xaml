<UserControl x:Class="OffensiveVS360.ToolWindow.FindingsWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <UserControl.Resources>
        <Style x:Key="SeverityBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style x:Key="SeverityText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" ToolBarTray.IsLocked="True">
            <Button x:Name="btnScanSolution" Click="BtnScanSolution_Click"
                    ToolTip="Scan Solution" Padding="4,2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x25B6;" Margin="0,0,4,0"/>
                    <TextBlock Text="Scan Solution"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button x:Name="btnClear" Click="BtnClear_Click"
                    ToolTip="Clear all findings" Padding="4,2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x2715;" Margin="0,0,4,0"/>
                    <TextBlock Text="Clear"/>
                </StackPanel>
            </Button>
            <Separator/>
            <TextBlock x:Name="lblStatus" VerticalAlignment="Center" Margin="4,0"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Text="No scan results"/>
        </ToolBar>

        <!-- Summary bar -->
        <Border Grid.Row="1" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                Padding="6,4" x:Name="summaryBar" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource SeverityBadge}" Background="#C00000">
                    <TextBlock Style="{StaticResource SeverityText}" Foreground="White"
                               x:Name="lblCritical" Text="0 Critical"/>
                </Border>
                <Border Style="{StaticResource SeverityBadge}" Background="#FF4500">
                    <TextBlock Style="{StaticResource SeverityText}" Foreground="White"
                               x:Name="lblHigh" Text="0 High"/>
                </Border>
                <Border Style="{StaticResource SeverityBadge}" Background="#FFA500">
                    <TextBlock Style="{StaticResource SeverityText}" Foreground="White"
                               x:Name="lblMedium" Text="0 Medium"/>
                </Border>
                <Border Style="{StaticResource SeverityBadge}" Background="#4682B4">
                    <TextBlock Style="{StaticResource SeverityText}" Foreground="White"
                               x:Name="lblLow" Text="0 Low"/>
                </Border>
                <Border Style="{StaticResource SeverityBadge}" Background="#808080">
                    <TextBlock Style="{StaticResource SeverityText}" Foreground="White"
                               x:Name="lblInfo" Text="0 Info"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Findings list -->
        <ListView Grid.Row="2" x:Name="listFindings"
                  SelectionChanged="ListFindings_SelectionChanged"
                  MouseDoubleClick="ListFindings_DoubleClick"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Severity" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="4,1"
                                        Background="{Binding SeverityColor}">
                                    <TextBlock Text="{Binding SeverityLabel}"
                                               Foreground="White" FontSize="10"
                                               FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Title" Width="280"
                                    DisplayMemberBinding="{Binding Title}"/>
                    <GridViewColumn Header="File" Width="180"
                                    DisplayMemberBinding="{Binding FileDisplay}"/>
                    <GridViewColumn Header="Line" Width="60"
                                    DisplayMemberBinding="{Binding Location}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Detail panel -->
        <Border Grid.Row="3" x:Name="detailPanel" Visibility="Collapsed"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="0,1,0,0" MaxHeight="200">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock x:Name="detailTitle" FontWeight="Bold" FontSize="13"
                               TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <TextBlock x:Name="detailFile" Foreground="Gray" FontSize="11"
                               Margin="0,0,0,6"/>
                    <TextBlock x:Name="detailEffect" TextWrapping="Wrap"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Recommendation:" FontWeight="SemiBold"
                               x:Name="recLabel" Margin="0,4,0,2" Visibility="Collapsed"/>
                    <TextBlock x:Name="detailRec" TextWrapping="Wrap"
                               Foreground="#2E7D32" Margin="0,0,0,4"/>
                    <TextBlock Text="Code:" FontWeight="SemiBold"
                               x:Name="codeLabel" Margin="0,4,0,2" Visibility="Collapsed"/>
                    <Border x:Name="codeBox" Background="#1E1E1E" CornerRadius="4"
                            Padding="8" Visibility="Collapsed">
                        <TextBlock x:Name="detailCode" Foreground="#D4D4D4"
                                   FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

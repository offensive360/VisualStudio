<Window x:Class="Offensive360.VSExt.FixGuidanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Offensive360 - Fix Guidance"
        Width="700" Height="620"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E"
        Foreground="#FFD4D4D4"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF569CD6"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
        <Style x:Key="CodeBlock" TargetType="Border">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="BorderBrush" Value="#FF3E3E3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,2,0,4"/>
        </Style>
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel Margin="20,16">
                <!-- Title -->
                <TextBlock x:Name="TitleText"
                           FontSize="18" FontWeight="Bold"
                           TextWrapping="Wrap"
                           Margin="0,0,0,4"/>

                <!-- Severity Badge -->
                <Border x:Name="SeverityBadge"
                        HorizontalAlignment="Left"
                        CornerRadius="3"
                        Padding="8,3"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="SeverityText"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="White"/>
                </Border>

                <!-- Description -->
                <TextBlock Text="Description" Style="{StaticResource SectionHeader}"/>
                <TextBlock x:Name="DescriptionText" Style="{StaticResource BodyText}"/>

                <!-- Risk -->
                <TextBlock Text="Risk Level" Style="{StaticResource SectionHeader}"/>
                <TextBlock x:Name="RiskText" Style="{StaticResource BodyText}"/>

                <!-- How to Fix -->
                <TextBlock Text="How to Fix" Style="{StaticResource SectionHeader}"/>
                <TextBlock x:Name="HowToFixText" Style="{StaticResource BodyText}"/>

                <!-- Vulnerable Code Pattern -->
                <TextBlock Style="{StaticResource SectionHeader}">
                    <Run Text="Vulnerable Pattern" Foreground="#FFCE9178"/>
                    <Run Text=" (Bad)" Foreground="#FFF44747"/>
                </TextBlock>
                <Border Style="{StaticResource CodeBlock}">
                    <TextBlock x:Name="BadPatternText"
                               FontFamily="Consolas, Courier New"
                               FontSize="12"
                               Foreground="#FFF44747"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Secure Code Pattern -->
                <TextBlock Style="{StaticResource SectionHeader}">
                    <Run Text="Secure Pattern" Foreground="#FFCE9178"/>
                    <Run Text=" (Good)" Foreground="#FF4EC9B0"/>
                </TextBlock>
                <Border Style="{StaticResource CodeBlock}">
                    <TextBlock x:Name="GoodPatternText"
                               FontFamily="Consolas, Courier New"
                               FontSize="12"
                               Foreground="#FF4EC9B0"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- CWE References -->
                <TextBlock Text="CWE References" Style="{StaticResource SectionHeader}"/>
                <TextBlock x:Name="CweText" Style="{StaticResource BodyText}"
                           Foreground="#FFDCDCAA"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom bar -->
        <Border Grid.Row="1"
                Background="#FF252526"
                BorderBrush="#FF3E3E3E"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Offensive360 SAST"
                           Foreground="#FF808080"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <Button Content="Close"
                        Width="90" Height="28"
                        HorizontalAlignment="Right"
                        Background="#FF0E639C"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="12"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
